# ===== REQUIRED =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ===== OPTIONAL =====
ADMIN_ID=0  # Telegram ID admin (optional)

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gadis_v81
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ===== REDIS =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== RABBITMQ =====
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ===== AI SETTINGS =====
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=500
AI_TIMEOUT=30
AI_MODEL_PRIMARY=deepseek
AI_MODEL_SECONDARY=claude

# ===== RATE LIMITING =====
RATE_LIMIT_MESSAGES=10
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=5

# ===== SEXUAL SETTINGS =====
SEXUAL_CONTENT_ENABLED=true
MAX_POSITIONS=50
MAX_AREAS=100
MAX_ACTIVITIES=50
CLIMAX_VARIATIONS=200
PUBLIC_RISK_ENABLED=true
BOT_INITIATIVE_ENABLED=true
AFTERCARE_ENABLED=true

# ===== WEBSOCKET =====
WS_HOST=0.0.0.0
WS_PORT=8765

# ===== WEBHOOK =====
WEBHOOK_URL=
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook

# ===== RAILWAY =====
RAILWAY_PUBLIC_DOMAIN=
RAILWAY_STATIC_URL=

# ===== MONITORING =====
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ===== BACKUP =====
BACKUP_ENABLED=true
BACKUP_INTERVAL=3600  # seconds
BACKUP_RETENTION_DAYS=7
BACKUP_S3_BUCKET=  # optional

# ===== SECURITY =====
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here
CORS_ORIGINS=*
